{
  "manifest_version": 3,
  "name": "Codex Work Gate",
  "version": "0.1.0",
  "description": "Blocks distracting sites unless Codex is actively working.",
  "key": "",
  "permissions": ["declarativeNetRequest", "nativeMessaging", "storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Codex Work Gate"
  },
  "options_page": "blocked.html"
}
